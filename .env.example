# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...        # service_role key — never expose to frontend
SUPABASE_JWT_SECRET=...

# ── OTP (generate: python -c "import secrets; print(secrets.token_hex(32))") ─
OTP_SECRET=<random-64-char-hex>

# ── Twilio SMS + WhatsApp (dev sandbox) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Meta WhatsApp Cloud API (production) ──────────────────────────────────────
META_WHATSAPP_TOKEN=...
META_WHATSAPP_PHONE_ID=...

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=casting@ruskmedia.com

# ── Frontend URL (for notification links) ─────────────────────────────────────
FRONTEND_URL=https://spotlight.ruskmedia.com
